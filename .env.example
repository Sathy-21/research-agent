# Copy this file to ".env" and fill in your real keys. The .env file is gitignored.

# Google Gemini API key — used for planning, synthesis, and composing the report.
# Get one (free) at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Tavily API key — used for web search.
# Get one at https://app.tavily.com/ (free tier available).
TAVILY_API_KEY=your-tavily-api-key-here
